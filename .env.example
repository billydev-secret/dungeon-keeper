# ── Environment selector ──────────────────────────────────────────────
BOT_ENV=dev                        # "dev" or "prod"

# ── Production ────────────────────────────────────────────────────────
DISCORD_TOKEN_PROD=your_prod_bot_token_here
GUILD_ID_PROD=
DB_PATH_PROD=dungeonkeeper.db
AUDIT_CHANNEL_PROD=

# ── Development ───────────────────────────────────────────────────────
DISCORD_TOKEN_DEV=your_dev_bot_token_here
GUILD_ID_DEV=
DB_PATH_DEV=dk_dev.db
AUDIT_CHANNEL_DEV=

# ── Dev-only flags ────────────────────────────────────────────────────
RESET_DEV_DB=0                     # 1 = refresh dev DB from prod on startup
SEED_DEV_FIXTURES=0                # 1 = load fixture data on startup

# ── Safety: expected bot user IDs (optional but recommended) ─────────
# If set, bot will exit on startup if connected user ID doesn't match.
# EXPECTED_BOT_ID_PROD=
# EXPECTED_BOT_ID_DEV=

# ── Dashboard (set DASHBOARD_ENABLED=1 to start the web UI) ──────────
# DASHBOARD_ENABLED=1
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8080

# ── Discord OAuth2 (optional — enables authenticated web access) ──────
# Without these, the dashboard runs in open LAN mode (no login required).
#
# 1. Go to https://discord.com/developers/applications → your app → OAuth2
# 2. Copy Client ID and Client Secret
# 3. Add redirect URI: https://yourdomain.com/callback
# 4. Generate a random session secret:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# SESSION_SECRET=
# DASHBOARD_BASE_URL=https://yourdomain.com

# ── Music cog (Lavalink + Spotify) ───────────────────────────────────
# Run `python scripts/setup_lavalink.py` once to download Lavalink + LavaSrc.
# Get Spotify creds from https://developer.spotify.com (Client Credentials flow,
# no redirect URI required).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# LAVALINK_PASSWORD=youshallnotpass
# LAVALINK_HOST=127.0.0.1
# LAVALINK_PORT=2333
# LAVALINK_HEAP_MB=512

# ====== Beta tools sidecar (DEV ONLY) ======================
# Sidecar control bot
DISCORD_TOKEN_TOOLS=
EXPECTED_BOT_ID_TOOLS=

# Puppets — 3 separate Discord apps registered in the Developer Portal
BETA_TOOLS_ENABLED=0
BETA_PUPPET_TOKEN_1=
BETA_PUPPET_TOKEN_2=
BETA_PUPPET_TOKEN_3=
EXPECTED_BOT_ID_PUPPET_1=
EXPECTED_BOT_ID_PUPPET_2=
EXPECTED_BOT_ID_PUPPET_3=

# Sim controls (used in later plans)
BETA_AMBIENT_RATE_MULTIPLIER=1.0
BETA_AMBIENT_AUTOSTART=1
BETA_LLM_BLEND=0

# ── LLM backend ───────────────────────────────────────────────────────────────
# Leave LLAMA_SERVER_URL empty to run the GGUF in-process (CPU, serialised).
# Set it to a llama.cpp `llama-server` on the LAN — e.g. a box with a GPU — to
# offload inference: nothing loads locally and calls stop queueing behind each
# other. Must be a private/loopback address; a public URL is refused (and the
# bot falls back to in-process) unless LLAMA_SERVER_ALLOW_PUBLIC=1.
LLAMA_SERVER_URL=
LLAMA_SERVER_TIMEOUT=120
LLAMA_SERVER_ALLOW_PUBLIC=0
